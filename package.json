{
  "name": "copilot-adapter",
  "displayName": "Copilot Adapter",
  "description": "AI Models Adapter for Copilot Chat",
  "version": "0.1.5",
  "publisher": "Eowl",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/eowl/copilot-adapter"
  },
  "engines": {
    "vscode": "^1.121.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "copilot chat",
    "byok",
    "deepseek",
    "minimax",
    "moonshot",
    "kimi",
    "qwen",
    "bigmodel",
    "glm",
    "language model"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "copilot-adapter-deepseek",
        "displayName": "DeepSeek",
        "configuration": {
          "type": "object",
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.deepseek.apiKey.title%",
              "description": "%copilot-adapter.provider.deepseek.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-minimax",
        "displayName": "MiniMax",
        "configuration": {
          "type": "object",
          "required": [
            "apiEndpoint",
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.minimax.apiEndpoint.title%",
              "enum": [
                "minimaxi.com",
                "minimax.io"
              ],
              "enumDescriptions": [
                "%copilot-adapter.provider.minimax.apiEndpoint.option.minimaxi.com%",
                "%copilot-adapter.provider.minimax.apiEndpoint.option.minimax.io%"
              ],
              "description": "%copilot-adapter.provider.minimax.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.minimax.apiKey.title%",
              "description": "%copilot-adapter.provider.minimax.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-qwen",
        "displayName": "Qwen",
        "configuration": {
          "type": "object",
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.qwen.apiEndpoint.title%",
              "description": "%copilot-adapter.provider.qwen.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.qwen.apiKey.title%",
              "description": "%copilot-adapter.provider.qwen.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-zhipu",
        "displayName": "Zhipu",
        "configuration": {
          "type": "object",
          "required": [
            "apiEndpoint",
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.zhipu.apiEndpoint.title%",
              "enum": [
                "bigmodel",
                "bigmodel-coding",
                "z.ai",
                "z.ai-coding"
              ],
              "enumDescriptions": [
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.bigmodel%",
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.bigmodel-coding%",
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.z.ai%",
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.z.ai-coding%"
              ],
              "description": "%copilot-adapter.provider.zhipu.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.zhipu.apiKey.title%",
              "description": "%copilot-adapter.provider.zhipu.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-moonshot",
        "displayName": "Moonshot",
        "configuration": {
          "type": "object",
          "required": [
            "apiEndpoint",
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.moonshot.apiEndpoint.title%",
              "enum": [
                "moonshot.cn",
                "moonshot.ai"
              ],
              "enumDescriptions": [
                "%copilot-adapter.provider.moonshot.apiEndpoint.option.moonshot.cn%",
                "%copilot-adapter.provider.moonshot.apiEndpoint.option.moonshot.ai%"
              ],
              "description": "%copilot-adapter.provider.moonshot.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.moonshot.apiKey.title%",
              "description": "%copilot-adapter.provider.moonshot.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-mimo",
        "displayName": "Xiaomi MIMO",
        "configuration": {
          "type": "object",
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.mimo.apiKey.title%",
              "description": "%copilot-adapter.provider.mimo.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-custom",
        "displayName": "Custom Models",
        "configuration": {
          "type": "object",
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiKey": {
              "type": "string",
              "secret": true,
              "minLength": 1,
              "description": "API key for the models",
              "title": "API Key"
            },
            "models": {
              "type": "array",
              "defaultSnippets": [
                {
                  "label": "New Model",
                  "description": "Add a new custom model configuration",
                  "body": [
                    {
                      "id": "$1",
                      "name": "$2",
                      "url": "$3",
                      "toolCalling": "^${4|true,false|}",
                      "vision": "^${5|true,false|}",
                      "maxInputTokens": "^${6:128000}",
                      "maxOutputTokens": "^${7:16000}"
                    }
                  ]
                }
              ],
              "items": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "string",
                    "description": "Unique identifier for the model"
                  },
                  "name": {
                    "type": "string",
                    "description": "Display name of the model"
                  },
                  "url": {
                    "type": "string",
                    "pattern": "^https?://.+",
                    "patternErrorMessage": "URL must start with http:// or https://",
                    "markdownDescription": "URL endpoint for the model.\n\n**Important:** Base URLs default to Chat Completions API. Explicit API paths are respected: `/chat/completions`, `/responses`, and `/v1/messages` (Anthropic-compatible). Use the `apiType` property to override the request/response format independently of the URL."
                  },
                  "apiType": {
                    "type": "string",
                    "enum": [
                      "chat-completions",
                      "responses",
                      "messages"
                    ],
                    "enumItemLabels": [
                      "Chat Completions",
                      "Responses",
                      "Messages"
                    ],
                    "enumDescriptions": [
                      "Chat Completions API",
                      "Responses API",
                      "Messages API"
                    ],
                    "title": "API Type",
                    "markdownDescription": "Request/response format used to talk to this endpoint:\n- `chat-completions`: Chat Completions API (default).\n- `responses`: Responses API.\n- `messages`: Messages API.\n\nWhen omitted, falls back to the group-level `apiType`, then to the URL path."
                  },
                  "toolCalling": {
                    "type": "boolean",
                    "description": "Whether the model supports tool calling"
                  },
                  "maxTools": {
                    "type": "number",
                    "description": "Maximum number of tools that can be called in a single request. Only applicable if `toolCalling` is true. If not set, tool calling is enabled with no specific limit."
                  },
                  "vision": {
                    "type": "boolean",
                    "description": "Whether the model supports vision capabilities"
                  },
                  "maxInputTokens": {
                    "type": "number",
                    "description": "Maximum number of input tokens supported by the model"
                  },
                  "maxOutputTokens": {
                    "type": "number",
                    "description": "Maximum number of output tokens supported by the model"
                  },
                  "editTools": {
                    "type": "array",
                    "description": "List of edit tools supported by the model. If this is not configured, the editor will try multiple edit tools and pick the best one.\n\n- 'find-replace': Find and replace text in a document.\n- 'multi-find-replace': Find and replace text in a document.\n- 'apply-patch': A file-oriented diff format used by some OpenAI models\n- 'code-rewrite': A general but slower editing tool that allows the model to rewrite and code snippet and provide only the replacement to the editor.",
                    "items": {
                      "type": "string",
                      "enum": [
                        "find-replace",
                        "multi-find-replace",
                        "apply-patch",
                        "code-rewrite"
                      ]
                    }
                  },
                  "thinking": {
                    "type": "boolean",
                    "default": false,
                    "description": "Whether the model supports thinking capabilities"
                  },
                  "thinkingTag": {
                    "type": "string",
                    "description": "An optional tag included in the request when thinking mode is enabled, allowing the model to adjust its response format or behavior accordingly."
                  },
                  "streaming": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether the model supports streaming responses. Defaults to true."
                  },
                  "zeroDataRetentionEnabled": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Whether Zero Data Retention (ZDR) is enabled for this endpoint. When `true`, `previous_response_id` will not be sent in requests via Responses API."
                  },
                  "supportsReasoningEffort": {
                    "oneOf": [
                      {
                        "type": "array",
                        "markdownDescription": "Simple form: flat array of effort level strings, e.g. `[\"low\", \"high\"]`. Each level auto-generates request fields using the `reasoningEffortFormat` (defaults to `chat-completions`). The first element is the default. Levels supported by mainstream OpenAI-compatible servers are `minimal`, `low`, `medium`, `high`.",
                        "items": {
                          "type": "string"
                        }
                      },
                      {
                        "type": "object",
                        "markdownDescription": "Full form: a ThinkingConfig object for complete control over options, labels, hints, and request body shape.",
                        "required": [
                          "default",
                          "options"
                        ],
                        "properties": {
                          "default": {
                            "type": "string",
                            "description": "Default thinking mode value."
                          },
                          "options": {
                            "type": "array",
                            "description": "Available thinking mode options.",
                            "items": {
                              "type": "object",
                              "required": [
                                "value"
                              ],
                              "properties": {
                                "value": {
                                  "type": "string",
                                  "description": "The option value sent in the request."
                                },
                                "label": {
                                  "type": "string",
                                  "description": "Display label for this option."
                                },
                                "hint": {
                                  "type": "string",
                                  "description": "Secondary description shown below the label."
                                },
                                "requestFields": {
                                  "type": "object",
                                  "description": "Arbitrary fields merged into the request body when this option is selected.",
                                  "additionalProperties": true
                                }
                              }
                            }
                          }
                        }
                      }
                    ]
                  },
                  "reasoningEffortFormat": {
                    "type": "string",
                    "enum": [
                      "chat-completions",
                      "responses"
                    ],
                    "markdownDescription": "Body shape used to forward the reasoning effort to the model. `chat-completions` sends a top-level `reasoning_effort` string. `responses` sends a nested `reasoning.effort` object. When unset the format follows the URL: `/responses` → nested, otherwise top-level."
                  },
                  "requestHeaders": {
                    "type": "object",
                    "description": "Additional HTTP headers to include with requests to this model. These reserved headers are not allowed and ignored if present: forbidden request headers (https://developer.mozilla.org/en-US/docs/Glossary/Forbidden_request_header), forwarding headers ('forwarded', 'x-forwarded-for', 'x-forwarded-host', 'x-forwarded-proto'), and others ('api-key', 'authorization', 'content-type', 'openai-intent', 'x-github-api-version', 'x-initiator', 'x-interaction-id', 'x-interaction-type', 'x-onbehalf-extension-id', 'x-request-id', 'x-vscode-user-agent-library-version'). Pattern-based forbidden headers ('proxy-*', 'sec-*', 'x-http-method*' with forbidden methods) are also blocked.",
                    "additionalProperties": {
                      "type": "string"
                    }
                  }
                },
                "required": [
                  "id",
                  "name",
                  "url",
                  "toolCalling",
                  "vision",
                  "maxInputTokens",
                  "maxOutputTokens"
                ]
              }
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "copilot-adapter.addApiKey",
        "title": "%copilot-adapter.command.addApiKey%"
      },
      {
        "command": "copilot-adapter.removeApiKey",
        "title": "%copilot-adapter.command.removeApiKey%"
      },
      {
        "command": "copilot-adapter.setVisionProxyModel",
        "title": "%copilot-adapter.command.visionProxy%"
      },
      {
        "command": "copilot-adapter.openSettings",
        "title": "%copilot-adapter.command.settings%"
      },
      {
        "command": "copilot-adapter.showLogs",
        "title": "%copilot-adapter.command.logs%"
      }
    ],
    "walkthroughs": [
      {
        "id": "copilotAdapterGettingStarted",
        "title": "%copilot-adapter.walkthrough.title%",
        "description": "%copilot-adapter.walkthrough.description%",
        "steps": [
          {
            "id": "addApiKey",
            "title": "%copilot-adapter.walkthrough.apiKey.title%",
            "description": "%copilot-adapter.walkthrough.apiKey.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.apiKey.media%"
            }
          },
          {
            "id": "showModels",
            "title": "%copilot-adapter.walkthrough.showModels.title%",
            "description": "%copilot-adapter.walkthrough.showModels.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.showModels.media%"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%copilot-adapter.walkthrough.advancedSettings.title%",
            "description": "%copilot-adapter.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.advancedSettings.media%"
            }
          },
          {
            "id": "visionProxy",
            "title": "%copilot-adapter.walkthrough.visionProxy.title%",
            "description": "%copilot-adapter.walkthrough.visionProxy.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.visionProxy.media%"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%copilot-adapter.config.title%",
      "properties": {
        "copilot-adapter.maxTokens": {
          "order": 1,
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%copilot-adapter.config.maxTokens.description%"
        },
        "copilot-adapter.requestTimeout": {
          "order": 2,
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "%copilot-adapter.config.requestTimeout.description%"
        },
        "copilot-adapter.requestRetries": {
          "order": 3,
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "%copilot-adapter.config.requestRetries.description%"
        },
        "copilot-adapter.visionProxyModel": {
          "order": 4,
          "type": "string",
          "default": "off",
          "markdownDescription": "%copilot-adapter.config.visionProxyModel.description%"
        },
        "copilot-adapter.visionProxyPrompt": {
          "order": 5,
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Task: produce an accurate, structured description of each image provided, for injection into a text-only language model conversation.\n\nCapture all visually significant content: text and code, UI layouts and controls, diagrams, charts, data tables, photographs, and spatial relationships.\n\nSingle image: write one cohesive description.\nMultiple images: label each \"Image 1:\", \"Image 2:\", etc., then add a \"Summary:\" section covering shared context and how the images relate.\n\nReport only what is clearly visible. Do not infer, guess, or embellish. Use concise neutral prose without addressing the user or narrating the process.",
          "description": "%copilot-adapter.config.visionProxyPrompt.description%"
        },
        "copilot-adapter.imageTokenEstimate": {
          "order": 6,
          "type": "number",
          "default": 1020,
          "minimum": 0,
          "description": "%copilot-adapter.config.imageTokenEstimate.description%"
        },
        "copilot-adapter.tokenRatio": {
          "order": 7,
          "type": "number",
          "default": 4,
          "minimum": 0.5,
          "maximum": 20,
          "markdownDescription": "%copilot-adapter.config.tokenRatio.description%"
        },
        "copilot-adapter.tokenRatioGlobal": {
          "order": 8,
          "type": "boolean",
          "default": false,
          "description": "%copilot-adapter.config.tokenRatioGlobal.description%"
        },
        "copilot-adapter.tokenRatioAutoCalibrate": {
          "order": 9,
          "type": "boolean",
          "default": true,
          "description": "%copilot-adapter.config.tokenRatioAutoCalibrate.description%"
        },
        "copilot-adapter.tokenRatioCalibrationThreshold": {
          "order": 10,
          "type": "number",
          "default": 0.1,
          "minimum": 0.01,
          "maximum": 1,
          "markdownDescription": "%copilot-adapter.config.tokenRatioCalibrationThreshold.description%",
          "enablement": "config.copilot-adapter.tokenRatioAutoCalibrate == true"
        },
        "copilot-adapter.debugMode": {
          "order": 11,
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "info",
            "meta",
            "verbose"
          ],
          "enumItemLabels": [
            "%copilot-adapter.config.debug.off.label%",
            "%copilot-adapter.config.debug.info.label%",
            "%copilot-adapter.config.debug.meta.label%",
            "%copilot-adapter.config.debug.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%copilot-adapter.config.debug.off.description%",
            "%copilot-adapter.config.debug.info.description%",
            "%copilot-adapter.config.debug.meta.description%",
            "%copilot-adapter.config.debug.verbose.description%"
          ],
          "markdownDescription": "%copilot-adapter.config.debug.description%"
        },
        "copilot-adapter.toolWarmup": {
          "order": 12,
          "type": "boolean",
          "default": false,
          "description": "%copilot-adapter.config.toolWarmup.description%"
        },
        "copilot-adapter.maxWarmupRounds": {
          "order": 13,
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "%copilot-adapter.config.maxWarmupRounds.description%",
          "enablement": "config.copilot-adapter.toolWarmup == true"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "package": "vsce package -o dist/",
    "test": "TS_NODE_PROJECT=tsconfig.test.json vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
