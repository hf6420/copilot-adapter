{
  "name": "copilot-adapter",
  "displayName": "Copilot Adapter",
  "description": "AI Models Adapter for Copilot Chat",
  "version": "0.1.3",
  "publisher": "Eowl",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/eowl/copilot-adapter"
  },
  "engines": {
    "vscode": "^1.121.0",
    "node": ">=24"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "copilot chat",
    "byok",
    "deepseek",
    "minimax",
    "moonshot",
    "kimi",
    "qwen",
    "bigmodel",
    "glm",
    "language model"
  ],
  "activationEvents": [
    "onUri",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "copilot-adapter-deepseek",
        "displayName": "DeepSeek",
        "configuration": {
          "type": "object",
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.deepseek.apiKey.title%",
              "description": "%copilot-adapter.provider.deepseek.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-minimax",
        "displayName": "MiniMax",
        "configuration": {
          "type": "object",
          "required": [
            "apiEndpoint",
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.minimax.apiEndpoint.title%",
              "enum": [
                "minimaxi.com",
                "minimax.io"
              ],
              "enumDescriptions": [
                "%copilot-adapter.provider.minimax.apiEndpoint.option.minimaxi.com%",
                "%copilot-adapter.provider.minimax.apiEndpoint.option.minimax.io%"
              ],
              "description": "%copilot-adapter.provider.minimax.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.minimax.apiKey.title%",
              "description": "%copilot-adapter.provider.minimax.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-qwen",
        "displayName": "Qwen",
        "configuration": {
          "type": "object",
          "required": [
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.qwen.apiEndpoint.title%",
              "description": "%copilot-adapter.provider.qwen.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.qwen.apiKey.title%",
              "description": "%copilot-adapter.provider.qwen.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-zhipu",
        "displayName": "Zhipu",
        "configuration": {
          "type": "object",
          "required": [
            "apiEndpoint",
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.zhipu.apiEndpoint.title%",
              "enum": [
                "bigmodel",
                "bigmodel-coding",
                "z.ai",
                "z.ai-coding"
              ],
              "enumDescriptions": [
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.bigmodel%",
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.bigmodel-coding%",
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.z.ai%",
                "%copilot-adapter.provider.zhipu.apiEndpoint.option.z.ai-coding%"
              ],
              "description": "%copilot-adapter.provider.zhipu.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.zhipu.apiKey.title%",
              "description": "%copilot-adapter.provider.zhipu.apiKey.description%",
              "secret": true
            }
          }
        }
      },
      {
        "vendor": "copilot-adapter-moonshot",
        "displayName": "Moonshot",
        "configuration": {
          "type": "object",
          "required": [
            "apiEndpoint",
            "apiKey"
          ],
          "properties": {
            "apiEndpoint": {
              "type": "string",
              "title": "%copilot-adapter.provider.moonshot.apiEndpoint.title%",
              "enum": [
                "moonshot.cn",
                "moonshot.ai"
              ],
              "enumDescriptions": [
                "%copilot-adapter.provider.moonshot.apiEndpoint.option.moonshot.cn%",
                "%copilot-adapter.provider.moonshot.apiEndpoint.option.moonshot.ai%"
              ],
              "description": "%copilot-adapter.provider.moonshot.apiEndpoint.description%"
            },
            "apiKey": {
              "type": "string",
              "title": "%copilot-adapter.provider.moonshot.apiKey.title%",
              "description": "%copilot-adapter.provider.moonshot.apiKey.description%",
              "secret": true
            }
          }
        }
      }
    ],
    "commands": [
      {
        "command": "copilot-adapter.addApiKey",
        "title": "%copilot-adapter.command.addApiKey%"
      },
      {
        "command": "copilot-adapter.removeApiKey",
        "title": "%copilot-adapter.command.removeApiKey%"
      },
      {
        "command": "copilot-adapter.setVisionProxyModel",
        "title": "%copilot-adapter.command.visionProxy%"
      },
      {
        "command": "copilot-adapter.openSettings",
        "title": "%copilot-adapter.command.settings%"
      },
      {
        "command": "copilot-adapter.showLogs",
        "title": "%copilot-adapter.command.logs%"
      },
      {
        "command": "copilot-adapter.openRequestRecordsFolder",
        "title": "%copilot-adapter.command.requestRecords%"
      }
    ],
    "walkthroughs": [
      {
        "id": "copilotAdapterGettingStarted",
        "title": "%copilot-adapter.walkthrough.title%",
        "description": "%copilot-adapter.walkthrough.description%",
        "steps": [
          {
            "id": "addApiKey",
            "title": "%copilot-adapter.walkthrough.apiKey.title%",
            "description": "%copilot-adapter.walkthrough.apiKey.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.apiKey.media%"
            }
          },
          {
            "id": "showModels",
            "title": "%copilot-adapter.walkthrough.showModels.title%",
            "description": "%copilot-adapter.walkthrough.showModels.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.showModels.media%"
            }
          },
          {
            "id": "advancedSettings",
            "title": "%copilot-adapter.walkthrough.advancedSettings.title%",
            "description": "%copilot-adapter.walkthrough.advancedSettings.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.advancedSettings.media%"
            }
          },
          {
            "id": "visionProxy",
            "title": "%copilot-adapter.walkthrough.visionProxy.title%",
            "description": "%copilot-adapter.walkthrough.visionProxy.description%",
            "media": {
              "markdown": "%copilot-adapter.walkthrough.visionProxy.media%"
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "%copilot-adapter.config.title%",
      "properties": {
        "copilot-adapter.maxTokens": {
          "order": 1,
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "%copilot-adapter.config.maxTokens.description%"
        },
        "copilot-adapter.requestTimeout": {
          "order": 2,
          "type": "number",
          "default": 60,
          "minimum": 0,
          "description": "%copilot-adapter.config.requestTimeout.description%"
        },
        "copilot-adapter.requestRetries": {
          "order": 3,
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 5,
          "description": "%copilot-adapter.config.requestRetries.description%"
        },
        "copilot-adapter.maxWarmupRounds": {
          "order": 4,
          "type": "number",
          "default": 3,
          "minimum": 1,
          "description": "%copilot-adapter.config.maxWarmupRounds.description%"
        },
        "copilot-adapter.visionProxyModel": {
          "order": 5,
          "type": "string",
          "default": "off",
          "markdownDescription": "%copilot-adapter.config.visionProxyModel.description%"
        },
        "copilot-adapter.visionProxyPrompt": {
          "order": 6,
          "type": "string",
          "editPresentation": "multilineText",
          "default": "Task: produce an accurate, structured description of each image provided, for injection into a text-only language model conversation.\n\nCapture all visually significant content: text and code, UI layouts and controls, diagrams, charts, data tables, photographs, and spatial relationships.\n\nSingle image: write one cohesive description.\nMultiple images: label each \"Image 1:\", \"Image 2:\", etc., then add a \"Summary:\" section covering shared context and how the images relate.\n\nReport only what is clearly visible. Do not infer, guess, or embellish. Use concise neutral prose without addressing the user or narrating the process.",
          "description": "%copilot-adapter.config.visionProxyPrompt.description%"
        },
        "copilot-adapter.imageTokenEstimate": {
          "order": 7,
          "type": "number",
          "default": 1020,
          "minimum": 0,
          "description": "%copilot-adapter.config.imageTokenEstimate.description%"
        },
        "copilot-adapter.tokenRatio": {
          "order": 8,
          "type": "number",
          "default": 4,
          "minimum": 0.5,
          "maximum": 20,
          "markdownDescription": "%copilot-adapter.config.tokenRatio.description%"
        },
        "copilot-adapter.tokenRatioGlobal": {
          "order": 9,
          "type": "boolean",
          "default": false,
          "description": "%copilot-adapter.config.tokenRatioGlobal.description%"
        },
        "copilot-adapter.tokenRatioAutoCalibrate": {
          "order": 10,
          "type": "boolean",
          "default": true,
          "description": "%copilot-adapter.config.tokenRatioAutoCalibrate.description%"
        },
        "copilot-adapter.tokenRatioCalibrationThreshold": {
          "order": 11,
          "type": "number",
          "default": 0.1,
          "minimum": 0.01,
          "maximum": 1,
          "markdownDescription": "%copilot-adapter.config.tokenRatioCalibrationThreshold.description%",
          "enablement": "config.copilot-adapter.tokenRatioAutoCalibrate == true"
        },
        "copilot-adapter.debugMode": {
          "order": 12,
          "type": "string",
          "default": "off",
          "enum": [
            "off",
            "info",
            "meta",
            "verbose"
          ],
          "enumItemLabels": [
            "%copilot-adapter.config.debug.off.label%",
            "%copilot-adapter.config.debug.info.label%",
            "%copilot-adapter.config.debug.meta.label%",
            "%copilot-adapter.config.debug.verbose.label%"
          ],
          "markdownEnumDescriptions": [
            "%copilot-adapter.config.debug.off.description%",
            "%copilot-adapter.config.debug.info.description%",
            "%copilot-adapter.config.debug.meta.description%",
            "%copilot-adapter.config.debug.verbose.description%"
          ],
          "markdownDescription": "%copilot-adapter.config.debug.description%"
        }
      }
    }
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true, maxRetries: process.platform === 'win32' ? 10 : 0 })\"",
    "compile": "npm run clean && tsc -p ./",
    "watch": "npm run clean && tsc -watch -p ./",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "package": "vsce package -o dist/",
    "test": "TS_NODE_PROJECT=tsconfig.test.json vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
